---
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";
const base = import.meta.env.BASE_URL; // "/portfolio-presence/full-time/"
---
<Layout
  title="Selected work — Anmol Bhargava"
  description="Four selected research projects across enterprise B2B SaaS (Atlassian), FinTech, and aviation. Behavioural research, pre-launch validation, and conversion behaviour."
>
  <section class="section section--cream">
    <div class="container">
      <p class="eyebrow">Selected work</p>
      <h1 class="display display--xl" style="color: var(--brick);">Four projects</h1>
      <p class="lede" style="color: var(--ink-soft);">
        Each one made the product team rethink something they thought they already
        understood. Atlassian, FinTech, and aviation work across behavioural research,
        pre-launch validation, and conversion behaviour.
      </p>

      <div class="work-grid">
        {projects.map((p) => (
          <a class="work-card" href={`${base}projects/${p.slug}`}>
            <span class="work-card__num">{p.num}</span>
            <div class="work-card__meta">
              Project {p.num} — {p.meta}{p.company ? `, ${p.company}` : ""}
            </div>
            <h3 class="work-card__title">{p.title}</h3>
            <p class="work-card__desc">{p.cardSummary}</p>
            <div class="work-card__tags">
              {p.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
            <div class="work-card__cta">Read full case study →</div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
