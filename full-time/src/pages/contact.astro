---
import Layout from "../layouts/Layout.astro";
---
<Layout
  title="Contact — Anmol Bhargava"
  description="Get in touch with Anmol Bhargava. Looking for senior UX research roles at product companies, with active interest in AI product research."
>
  <section class="section section--cream">
    <div class="container" style="max-width: 760px;">
      <p class="eyebrow">Contact</p>
      <h1 class="display display--xl" style="color: var(--brick);">Let's talk.</h1>
      <p class="lede">
        Looking for a senior UX research role at a product company. Happy to chat
        about open positions, AI product research, behavioural work, or anything in
        between.
      </p>

      <div class="contact-list">
        <div class="contact-list__row">
          <div class="contact-list__k">Email</div>
          <a class="contact-list__v" href="mailto:anmol.bhargava246@gmail.com">
            anmol.bhargava246@gmail.com
          </a>
        </div>
        <div class="contact-list__row">
          <div class="contact-list__k">LinkedIn</div>
          <a
            class="contact-list__v"
            href="https://www.linkedin.com/in/anmolbhargava4/"
            target="_blank"
            rel="noopener noreferrer"
          >
            linkedin.com/in/anmolbhargava4
          </a>
        </div>
        <div class="contact-list__row">
          <div class="contact-list__k">Phone</div>
          <a class="contact-list__v" href="tel:+919082620650">+91 90826 20650</a>
        </div>
        <div class="contact-list__row">
          <div class="contact-list__k">Based in</div>
          <div class="contact-list__v">Bangalore, India</div>
        </div>
      </div>

      <div class="cta-row" style="margin-top: 2.5rem;">
        <a
          href="mailto:anmol.bhargava246@gmail.com?subject=UX%20research%20role&body=Hi%20Anmol%2C"
          class="btn btn--filled-brick"
        >
          Email me
        </a>
        <a
          href="https://www.linkedin.com/in/anmolbhargava4/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn"
        >
          Connect on LinkedIn
        </a>
      </div>
    </div>
  </section>
</Layout>
