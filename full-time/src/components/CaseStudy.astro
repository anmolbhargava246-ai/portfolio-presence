---
import { projects } from "../data/projects";

export interface TldrItem { k: string; v: string; }
export interface Insight { lead: string; body: string; }

export interface Props {
  slug: string;
  problem: string[];      // paragraphs
  reframe?: { label: string; layers: { label: string; body: string }[]; intro?: string };
  findings: Insight[];
  changed: string[];
  stakeholders?: string;  // optional "How I worked with stakeholders" paragraph
  takeaway: string;
  tldr: TldrItem[];
  strategicShift: string;
}

const {
  slug,
  problem,
  reframe,
  findings,
  changed,
  stakeholders,
  takeaway,
  tldr,
  strategicShift,
} = Astro.props;

const idx = projects.findIndex((p) => p.slug === slug);
const project = projects[idx];
const next = projects[(idx + 1) % projects.length];
const base = import.meta.env.BASE_URL; // "/portfolio-presence/full-time/"
---
<article class="section section--cream">
  <div class="container" style="max-width: 820px;">
    <a href={`${base}#work`} class="back-link">← Selected work</a>
    <div class="case-meta">Project {project.num} · {project.meta}</div>
    <h1 class="display display--xl" style="color: var(--brick);">{project.title}</h1>
    <p class="lede" style="margin-top: 1rem;">{project.subtitle}</p>
    <div class="case-tags">
      {project.tags.map((t) => <span class="tag">{t}</span>)}
    </div>

    <!-- TL;DR -->
    <div class="tldr">
      <div class="tldr__label">TL;DR</div>
      <div class="tldr__grid">
        {tldr.map((item) => (
          <div>
            <div class="tldr__k">{item.k}</div>
            <div class="tldr__v">{item.v}</div>
          </div>
        ))}
      </div>
      <div class="tldr__shift">
        <div class="tldr__k">Strategic shift</div>
        <div class="tldr__v">{strategicShift}</div>
      </div>
    </div>

    <!-- Problem -->
    <div class="section-label">The problem</div>
    <div class="prose">
      {problem.map((p) => <p>{p}</p>)}
    </div>

    <!-- Optional reframe -->
    {reframe && (
      <>
        <div class="section-label">{reframe.label}</div>
        <div class="prose">
          {reframe.intro && <p>{reframe.intro}</p>}
        </div>
        {reframe.layers.map((l) => (
          <div class="insight">
            <div class="insight__lead">{l.label}</div>
            <p class="insight__body">{l.body}</p>
          </div>
        ))}
      </>
    )}

    <!-- Findings -->
    <div class="section-label">What we found</div>
    {findings.map((f) => (
      <div class="insight">
        <div class="insight__lead">{f.lead}</div>
        <p class="insight__body">{f.body}</p>
      </div>
    ))}

    <!-- Changed -->
    <div class="section-label">What changed</div>
    <ul class="checklist">
      {changed.map((c) => <li><span>{c}</span></li>)}
    </ul>

    <!-- Optional stakeholders -->
    {stakeholders && (
      <>
        <div class="section-label">How I worked with stakeholders</div>
        <div class="prose"><p>{stakeholders}</p></div>
      </>
    )}

    <!-- Takeaway -->
    <div class="pullquote">
      <div class="pullquote__label">Takeaway</div>
      <p class="pullquote__text">{takeaway}</p>
    </div>

    <!-- CTA -->
    <div class="cta-row">
      <a href={`${base}projects/${next.slug}`} class="btn btn--filled-brick">
        Next: {next.title.length > 40 ? next.title.slice(0, 40) + "…" : next.title} →
      </a>
      <a href={`${base}#contact`} class="btn">Get in touch</a>
    </div>
  </div>
</article>
